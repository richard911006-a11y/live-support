{
  "name": "@live-support/widget",
  "version": "1.0.0",
  "private": true,
  "description": "Embeddable React customer support widget for live-support.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "pages:dev": "wrangler pages dev public",
    "pages:deploy": "wrangler pages deploy public --project-name live-support-widget --branch production"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@live-support/types": "workspace:*",
    "@live-support/utils": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "6.0.3",
    "wrangler": "catalog:"
  }
}
