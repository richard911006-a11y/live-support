{
  "name": "live-support",
  "version": "1.0.0",
  "private": true,
  "description": "A lightweight realtime customer support platform built for the Cloudflare ecosystem.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "eslint . --max-warnings 0 && turbo run typecheck && turbo run test && prettier --check .",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "doctor": "node scripts/run-ts.mjs scripts/doctor.ts",
    "telegram:doctor": "node scripts/run-ts.mjs scripts/telegram-doctor.ts",
    "setup": "node scripts/run-ts.mjs scripts/setup.ts",
    "deploy": "node scripts/run-ts.mjs scripts/deploy.ts",
    "deploy:pages": "pnpm --filter @live-support/widget pages:deploy"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "turbo": "2.10.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10",
    "wrangler": "catalog:"
  }
}
